# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
*.tsbuildinfo

# Database (contains all user data: chats, characters, lorebooks, presets, connections, agents, etc.)
*.db
*.db-shm
*.db-wal
*.db-journal

# Environment (may contain encryption keys)
.env
.env.local
.env.production

# Local pnpm config (created by start-termux.sh for platform fixes)
.npmrc

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# User data — uploaded avatars, backgrounds, sprites, and runtime files
data/
packages/server/data/

# Logs
*.log

# Custom agents (personal)
.github/agents/qa.agent.md

# Build output
release/
release-artifacts/

# Installer artifacts are published on GitHub Releases, not tracked in source
installer/*.exe
win/installer/*.exe
