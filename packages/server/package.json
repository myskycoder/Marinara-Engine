{
  "name": "@marinara-engine/server",
  "version": "1.5.6",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --ignore ./data --ignore ./node_modules --ignore ../../node_modules src/index.ts",
    "build": "tsc && node ./scripts/write-build-meta.mjs && node -e \"const fs=require('fs');fs.cpSync('src/db/default-preset.json','dist/db/default-preset.json');fs.cpSync('src/assets','dist/assets',{recursive:true});\"",
    "start": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "clean": "node -e \"const fs=require('fs');['dist','*.tsbuildinfo'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\"",
    "lint": "tsc -b ../shared && tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.cts",
    "db:push": "drizzle-kit push --config=drizzle.config.cts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.cts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.cts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.0",
    "@huggingface/transformers": "^3.8.1",
    "@libsql/client": "^0.15.0",
    "@marinara-engine/shared": "workspace:*",
    "adm-zip": "^0.5.16",
    "buttplug": "4.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "nanoid": "^5.1.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "png-chunk-text": "^1.0.0",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "undici": "^7.24.6",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "onnxruntime-node": "^1.24.3",
    "onnxruntime-web": "^1.24.3",
    "sharp": "^0.34.5",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
